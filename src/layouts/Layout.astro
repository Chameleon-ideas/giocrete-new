---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Analytics from "@vercel/analytics/astro";

import { client } from "../sanity/lib/client";
import { settingsQuery } from "../sanity/lib/queries";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  headerVariant?: "light" | "dark";
}

const { title, description, ogImage, headerVariant = "dark" } = Astro.props;

// Fetch Global Settings for Logo, Navigation, Footer, etc.
const settings = await client.fetch(settingsQuery);

const siteTitle = title ? `${title} | GioCrete` : "GioCrete";
const siteDesc = description ?? "Toronto’s Premier Infrastructure Specialists.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteDesc} />
    <link rel="icon" href="/favicon.ico" />
    <title>{siteTitle}</title>

    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDesc} />

    <!-- GSAP CDN -->
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
    ></script>

    <script is:inline>
      // Early theme detection to prevent flash
      (function () {
        const theme = localStorage.getItem("theme") || "light";
        document.documentElement.setAttribute("data-theme", theme);
        if (theme === "dark") document.documentElement.classList.add("dark");
      })();
    </script>
  </head>
  <body class="antialiased selection:bg-accent selection:text-black">
    <div class="framed-layout">
      <Navbar variant={headerVariant} settings={settings} />
      <main id="main-content">
        <slot />
      </main>
      <Footer settings={settings} />
    </div>

    <!-- Page Transition Overlay -->
    <div class="page-transition" aria-hidden="true">
      <div class="pt-layer"></div>
    </div>

    <Analytics />

    <script is:inline>
      (function () {
        if (typeof gsap === "undefined") return;
        gsap.registerPlugin(ScrollTrigger);

        // Industrial Weighted Ease
        const editorialEase = "cubic-bezier(0.85, 0, 0.15, 1)";

        // ── Theme Toggle (Robust Delegation) ──────────────────────────────
        window.addEventListener("click", (e) => {
          const btn = e.target.closest(".theme-toggle");
          if (btn) {
            e.preventDefault();
            const current = document.documentElement.getAttribute("data-theme");
            const next = current === "dark" ? "light" : "dark";

            document.documentElement.setAttribute("data-theme", next);
            document.documentElement.classList.toggle("dark", next === "dark");
            localStorage.setItem("theme", next);
          }
        });

        // ── Reveal Animations ─────────────────────────────────────────────
        const reveals = document.querySelectorAll(".reveal-up");
        reveals.forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, y: 50 },
            {
              opacity: 1,
              y: 0,
              duration: 1.2,
              ease: editorialEase,
              scrollTrigger: {
                trigger: el,
                start: "top 85%",
                toggleActions: "play none none none",
              },
            },
          );
        });

        // ── Text Line Reveal ─────────────────────────────────────────────
        const lineReveals = document.querySelectorAll(".line-reveal span");
        if (lineReveals.length) {
          gsap.to(lineReveals, {
            y: "0%",
            duration: 1.2,
            stagger: 0.1,
            ease: "power4.out",
            delay: 0.2,
          });
        }

        // ── Page Transitions ──────────────────────────────────────────────
        const transitionLayer = document.querySelector(".pt-layer");
        if (transitionLayer) {
          // Function to play entrance animation
          const playEntrance = () => {
            gsap.to(transitionLayer, {
              scaleX: 0,
              duration: 0.8,
              ease: "power4.inOut",
              transformOrigin: "right",
            });
          };

          // Play immediately on load
          playEntrance();

          // Handle browser back/forward cache (bfcache)
          window.addEventListener("pageshow", (event) => {
            if (event.persisted) {
              playEntrance();
            }
          });

          // Exit logic for links
          document.querySelectorAll("a[href]").forEach((link) => {
            const href = link.getAttribute("href");
            if (
              !href ||
              href.startsWith("#") ||
              href.startsWith("http") ||
              href.includes(":")
            )
              return;

            link.addEventListener("click", (e) => {
              const currentPath = window.location.pathname;
              const targetPath = new URL(link.href).pathname;

              // Don't animate if clicking same page link
              if (currentPath === targetPath) return;

              e.preventDefault();
              gsap
                .timeline({
                  onComplete: () => {
                    window.location.href = href;
                  },
                })
                .to(transitionLayer, {
                  scaleX: 1,
                  duration: 0.6,
                  ease: "power4.inOut",
                  transformOrigin: "left",
                });
            });
          });
        }
      })();
    </script>

    <style is:global>
      .framed-layout {
        position: relative;
        overflow-x: hidden;
      }

      /* Smooth scrolling support */
      html {
        scroll-behavior: smooth;
      }

      /* Selection colors */
      ::selection {
        background: var(--clr-accent);
        color: #000;
      }
    </style>
  </body>
</html>

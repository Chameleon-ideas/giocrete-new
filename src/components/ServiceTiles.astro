---
interface Props {
  services: any[];
  title?: string;
  description?: string;
  tagline?: string;
}

const { 
  services, 
  title = "Industrial <br/><span class='text-accent italic'>Operations</span>",
  description = "Precision execution in critical civil infrastructure. We handle the complexities of the GTA's underground assets.",
  tagline = "Founded 2007 // Unionized Crew"
} = Astro.props;
---

<section class="section bg-white dark:bg-bg-dark transition-colors duration-700">
  <div class="container">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
      <div class="lg:col-span-4 reveal-up">
        <span class="label">Specializations</span>
        <h2 class="editorial-title text-5xl md:text-7xl mb-8 text-charcoal dark:text-light" set:html={title} />
        <p class="text-lg text-muted dark:text-light/60 leading-relaxed mb-12 max-w-sm">
          {description}
        </p>
        <div class="hidden lg:block h-[1px] w-24 bg-accent/30"></div>
        <p class="mt-8 text-[10px] font-bold uppercase tracking-[0.3em] text-muted/40 dark:text-white/20">{tagline}</p>
      </div>

      <div class="lg:col-span-8">
        <div class="flex flex-col gap-6">
          {services.map((service, idx) => (
            <a href={`/services/${service.slug}`} class="group relative block overflow-hidden bg-black no-underline reveal-up">
              <div class="aspect-[21/9] md:aspect-[24/8] overflow-hidden">
                <img 
                  src={service.image} 
                  alt={service.title} 
                  loading="lazy"
                  decoding="async"
                  width="1200"
                  height="800"
                  class="w-full h-full object-cover grayscale opacity-50 transition-all duration-1000 group-hover:scale-105 group-hover:opacity-100 group-hover:grayscale-0"
                />
              </div>
              
              <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-12 bg-gradient-to-t from-black/95 via-black/40 to-transparent transition-all duration-500 group-hover:via-black/60">
                <div class="flex justify-between items-end">
                   <div>
                     <span class="text-[10px] font-bold text-accent uppercase tracking-widest block mb-2 opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500">0{idx + 1} // Primary Expertise</span>
                     <h3 class="editorial-title text-3xl md:text-5xl text-white group-hover:text-accent transition-colors duration-500 drop-shadow-lg">{service.title}</h3>
                   </div>
                   <div class="h-12 w-12 border border-white/20 flex items-center justify-center text-white group-hover:bg-accent group-hover:border-accent group-hover:text-black transition-all duration-500 rounded-full">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M7 17L17 7M17 7H7M17 7V17" />
                      </svg>
                   </div>
                </div>
              </div>

              {/* Decorative Scanline */}
              <div class="absolute top-0 left-0 w-full h-[1px] bg-accent/20 group-hover:h-full group-hover:bg-accent/5 transition-all duration-700"></div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

---
interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { 
  title = "Looking to build Toronto's future?", 
  subtitle = "We're always looking for skilled laborers, operators, and pipe layers to join our union crew. Proud members of Local 183 & Local 793.",
  ctaText = "Apply Now →",
  ctaHref = "/careers"
} = Astro.props;
---

<section class="section bg-concrete border-y border-site-border overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-12 reveal-up">
      <div class="max-w-2xl">
        <h2 class="text-4xl md:text-5xl font-bold uppercase tracking-tighter leading-[1.1] mb-6">
          {title}
        </h2>
        <p class="text-charcoal/70 text-lg leading-relaxed mb-8">
          {subtitle}
        </p>
        <a href={ctaHref} class="btn btn--primary px-10 py-4 text-sm tracking-[0.2em] uppercase">
          {ctaText}
        </a>
      </div>

      <div class="w-full lg:w-1/3 grid grid-cols-2 gap-4">
        <!-- Placeholder Badge boxes as requested -->
        <div class="aspect-video bg-white border border-site-border flex items-center justify-center p-6 grayscale hover:grayscale-0 transition-all">
          <span class="text-xs font-bold uppercase tracking-widest text-charcoal/30 text-center">Local 183</span>
        </div>
        <div class="aspect-video bg-white border border-site-border flex items-center justify-center p-6 grayscale hover:grayscale-0 transition-all">
          <span class="text-xs font-bold uppercase tracking-widest text-charcoal/30 text-center">Local 793</span>
        </div>
        <div class="aspect-video bg-white border border-site-border flex items-center justify-center p-6 grayscale hover:grayscale-0 transition-all">
          <span class="text-xs font-bold uppercase tracking-widest text-charcoal/30 text-center">City of Toronto</span>
        </div>
        <div class="aspect-video bg-white border border-site-border flex items-center justify-center p-6 grayscale hover:grayscale-0 transition-all">
          <span class="text-xs font-bold uppercase tracking-widest text-charcoal/30 text-center">COR Certified</span>
        </div>
      </div>
    </div>
  </div>
</section>

---
import Layout from '../../layouts/Layout.astro';
import { HoverButton } from '../../components/HoverButton';
import { services } from '../../data/services';

export const prerender = true;

export async function getStaticPaths() {
  return services.map(service => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout title={service.title} headerVariant="dark">
  <!-- Dynamic Hero -->
  <section class="min-h-[85vh] relative flex flex-col justify-end bg-charcoal text-light overflow-hidden px-6 py-24 md:p-24 lg:p-32">
    <div class="absolute inset-0 z-0">
      <img 
        src={service.image} 
        alt={service.title} 
        class="w-full h-full object-cover opacity-30 grayscale group-hover:grayscale-0 transition-all duration-1000"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/20 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-6xl reveal-up">
      <span class="label !text-accent">Specialization</span>
      <h1 class="editorial-title text-[clamp(2.5rem,14vw,5.5rem)] md:text-8xl lg:text-[10rem] mb-12 leading-[0.85] uppercase">
        {service.title.split(' ')[0]} <br/>
        <span class="text-accent italic">{service.title.split(' ').slice(1).join(' ')}</span>
      </h1>
      <p class="text-lg md:text-2xl text-light/50 max-w-2xl leading-relaxed mb-12">
        {service.shortDesc}
      </p>
      
      <div class="flex flex-wrap gap-6 md:gap-12 mt-12 border-t border-white/10 pt-12">
        {service.stats.map(stat => (
          <div>
            <span class="text-2xl md:text-4xl font-semibold editorial-title block text-light">{stat.value}</span>
            <span class="text-[10px] uppercase tracking-widest text-white/40">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Content & Features -->
  <section class="section bg-white dark:bg-bg-dark transition-colors duration-700">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-32">
        
        <!-- Left: Deep Dive -->
        <div class="lg:col-span-7 reveal-up">
          <span class="label">Operations Overview</span>
          <h2 class="editorial-title text-3xl md:text-5xl mb-12 text-charcoal dark:text-light">
            Bringing Mechanical <br/><span class="italic text-accent">Precision</span> to Infrastructure.
          </h2>
          <div class="prose prose-xl dark:prose-invert max-w-none text-muted dark:text-light/60 space-y-8">
            <p>{service.fullDesc}</p>
            <p>
              Every municipal collaboration is treated with the same level of rigorous oversight. We ensure that all technical specifications are met, from compaction testing to final inspections, guaranteed by our Local 183 and 793 workforce.
            </p>
          </div>
        </div>

        <!-- Right: Technical Specs -->
        <div class="lg:col-span-5 reveal-up">
          <div class="bg-concrete dark:bg-black p-6 md:p-12 border border-site-border dark:border-white/5 sticky top-32">
             <span class="label">Technical Scope</span>
             <ul class="space-y-8">
                {service.features.map(feature => (
                  <li class="flex items-start gap-4">
                     <span class="text-accent mt-1">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                           <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                     </span>
                     <span class="text-sm font-bold uppercase tracking-widest text-charcoal dark:text-light">{feature}</span>
                  </li>
                ))}
             </ul>
             
             <div class="mt-16 pt-12 border-t border-charcoal/10 dark:border-white/10">
                <p class="text-xs text-muted dark:text-white/30 uppercase tracking-[0.2em] mb-8">Ready to discuss your municipal project requirements?</p>
                <a href="/contact" class="no-underline block">
                  <HoverButton client:load variant="primary" className="w-full !py-5">
                    Start Consultation
                  </HoverButton>
                </a>
             </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="section bg-charcoal text-light relative overflow-hidden">
     <div class="absolute inset-0 opacity-[0.03] select-none pointer-events-none flex items-center justify-center">
        <span class="text-[clamp(10rem,30vw,30rem)] font-bold editorial-title whitespace-nowrap">{service.title.split(' ')[0]}</span>
     </div>
     
     <div class="container relative z-10 text-center reveal-up">
        <h3 class="editorial-title text-3xl md:text-7xl mb-12">Building for the <br/><span class="italic text-accent">Next Generation</span>.</h3>
        <a href="/projects" class="no-underline inline-block">
          <HoverButton client:load variant="secondary" className="!px-16 !py-6 !text-lg !text-current">
            View Recent Projects
          </HoverButton>
        </a>
     </div>
  </section>
</Layout>
